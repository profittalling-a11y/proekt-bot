# Exchange Selection (okx, bybit, bingx)
EXCHANGE=okx

# API Credentials - can be set via dashboard or here
# OKX
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here

# Bybit
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# BingX
BINGX_API_KEY=your_bingx_api_key_here
BINGX_API_SECRET=your_bingx_api_secret_here

# Trading Mode: testnet, paper, live
TRADING_MODE=testnet

# Trading Parameters (can be changed via dashboard)
# Timeframe options: 5, 10, 15, 30, 60, 120, 240
TIMEFRAME=15
SUPERTREND_MULTIPLIER=3.0
ATR_PERIOD=10
POLLING_INTERVAL=30

# Market Scanning
AUTO_SCAN=true
MIN_VOLUME_24H=1000000
MAX_SYMBOLS=10

# Manual symbols (used only if AUTO_SCAN=false)
# Format depends on exchange:
# OKX: BTC-USDT-SWAP,ETH-USDT-SWAP
# Bybit: BTCUSDT,ETHUSDT
# BingX: BTC-USDT,ETH-USDT
SYMBOLS=BTC-USDT-SWAP,ETH-USDT-SWAP,SOL-USDT-SWAP

# Risk Management - Fixed Position Sizing
FIXED_POSITION_SIZE=1.0
RISK_PER_POSITION=2.0
MAX_POSITIONS=10

# Leverage per symbol
LEVERAGE_CONFIG=BTC-USDT-SWAP:50,ETH-USDT-SWAP:50,SOL-USDT-SWAP:25

# Risk Management - Account Level
MAX_DAILY_LOSS=20.0
COOLDOWN_AFTER_LOSS=300
MIN_BALANCE=100.0

# Telegram Notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Logging
LOG_LEVEL=INFO
